# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# MySQL (Docker service name "db", NOT localhost — the backend container
# reaches the database container through the Docker network, so it must
# use the service name defined in docker-compose.yml)
DB_HOST=db
DB_PORT=3306
DB_NAME=studysync
DB_USER=studysync
DB_PASSWORD=studysync123
DB_ROOT_PASSWORD=root123

# S3-compatible storage (LocalStack, Docker service name "s3")
S3_ENDPOINT=http://host.docker.internal:4566
S3_REGION=us-east-1
S3_BUCKET=studysync-materials
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
# Used to build public download URLs shown to the browser. The browser runs
# on the host machine, not inside the Docker network, so this ONE value is
# allowed to say "localhost" — it's the host-mapped port of the "s3" service.
S3_PUBLIC_ENDPOINT=http://localhost:4566
